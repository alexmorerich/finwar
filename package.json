{
  "name": "finwar",
  "version": "4.0.0",
  "description": "FinWar v4 — Geopolitical Financial Threat Simulation Engine. The portfolio-INDEPENDENT TRUTH layer that emits a typed WorldState (events × per-bucket asset risk × binding constraints) consumed by the FinOS decision pipeline. Models the world; never sees a portfolio; never recommends an action.",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test test/*.test.ts",
    "test:legacy": "node tests/golden.test.js && node tests/terrain.test.js",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "sim": "node engine/engine.js",
    "serve": "python3 -m http.server 8080"
  },
  "keywords": [
    "finwar",
    "worldstate",
    "geopolitical",
    "sanctions",
    "capital-controls",
    "risk",
    "cloudflare-workers",
    "deterministic"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "wrangler": "^4.0.0"
  }
}
